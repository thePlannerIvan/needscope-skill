{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "05_quality_gate",
  "description": "Step 5: 编码质量 Gate 合约（v3.2 — 含五组审核与非法资格组合检查）",
  "type": "object",
  "required": [
    "sample_size",
    "random_review",
    "high_like_review",
    "context_risk_review",
    "primary_evidence_review",
    "supporting_evidence_review",
    "critical_errors",
    "gate_result",
    "rerun_required"
  ],
  "properties": {
    "sample_size": {
      "type": "integer",
      "description": "审核抽样总数量"
    },
    "random_review": {
      "type": "object",
      "required": ["sample_count", "error_count", "passed"],
      "properties": {
        "sample_count": { "type": "integer", "description": "该组样本数" },
        "error_count": { "type": "integer", "description": "该组错误数" },
        "passed": { "type": "boolean", "description": "该组是否通过审核" },
        "findings": { "type": "string", "description": "该组审核发现总结" }
      },
      "description": "随机抽样审核：从编码结果中随机抽取的样本，覆盖低置信和活跃原型。"
    },
    "high_like_review": {
      "type": "object",
      "required": ["sample_count", "error_count", "passed"],
      "properties": {
        "sample_count": { "type": "integer", "description": "该组样本数" },
        "error_count": { "type": "integer", "description": "该组错误数" },
        "passed": { "type": "boolean", "description": "该组是否通过审核" },
        "findings": { "type": "string", "description": "该组审核发现总结" }
      },
      "description": "高互动样本定向审核：高赞/高回复文本的 signal_owner 和 asset_eligibility 是否有系统误判。"
    },
    "context_risk_review": {
      "type": "object",
      "required": ["sample_count", "error_count", "passed"],
      "properties": {
        "sample_count": { "type": "integer", "description": "该组样本数" },
        "error_count": { "type": "integer", "description": "该组错误数" },
        "passed": { "type": "boolean", "description": "该组是否通过审核" },
        "findings": { "type": "string", "description": "该组审核发现总结" }
      },
      "description": "上下文风险样本审核：doge/哈哈/偷笑/评论区/弹幕/粉丝等标记文本是否被误归为 brand 或 primary_eligible。"
    },
    "primary_evidence_review": {
      "type": "object",
      "required": ["sample_count", "error_count", "passed"],
      "properties": {
        "sample_count": { "type": "integer", "description": "该组样本数" },
        "error_count": { "type": "integer", "description": "该组错误数" },
        "passed": { "type": "boolean", "description": "该组是否通过审核" },
        "findings": { "type": "string", "description": "该组审核发现总结" }
      },
      "description": "主落点证据样本审核：所有 asset_eligibility=primary_eligible 的文本逐条审查，确认无 founder/content/campaign/community/platform/category/competitor/fan 文本被错误进入。"
    },
    "supporting_evidence_review": {
      "type": "object",
      "required": ["sample_count", "error_count", "passed"],
      "properties": {
        "sample_count": { "type": "integer", "description": "该组样本数" },
        "error_count": { "type": "integer", "description": "该组错误数" },
        "passed": { "type": "boolean", "description": "该组是否通过审核" },
        "findings": { "type": "string", "description": "该组审核发现总结" }
      },
      "description": "v3.2 辅助证据审核：检查 asset_eligibility=secondary_only 的自有信号是否只是轻微语境污染，而不是 founder/content/粉丝/平台/纯 campaign 信号。"
    },
    "critical_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "original_text", "current_encoding", "correction"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["polarity_reversal", "misattribution", "missed_signal", "over_assignment", "ineligible_primary", "other"]
          },
          "original_text": { "type": "string", "description": "原文" },
          "current_encoding": { "type": "string", "description": "当前编码结果" },
          "correction": { "type": "string", "description": "正确编码是什么" }
        }
      },
      "description": "严重错误列表。ineligible_primary 是 v3 新增：asset_eligibility 误判为 primary_eligible。"
    },
    "systematic_error_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "系统性错误类型列表（同一类型错误 ≥3 次时记录）"
    },
    "critical_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "primary_evidence_contaminated",
          "meme_joy_as_primary_evidence",
          "systematic_signal_owner_errors",
          "systematic_asset_eligibility_errors",
          "high_like_not_reviewed_separately",
          "illegal_owner_eligibility_combo"
        ]
      },
      "description": "v3 致命失败条件。触发任一条件则 gate 直接 fail。"
    },
    "gate_result": {
      "type": "string",
      "enum": ["pass", "fail_rerun", "fail_prompt_revision"],
      "description": "Gate 结果"
    },
    "rerun_required": {
      "type": "boolean",
      "description": "是否需要重跑"
    },
    "patch_instructions": {
      "type": "string",
      "description": "如果需要重跑，具体的修正说明"
    }
  }
}
