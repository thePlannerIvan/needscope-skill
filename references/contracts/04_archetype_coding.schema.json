{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "04_archetype_coding",
  "description": "Step 4: NeedScope 语义编码合约（v3.2 — 含 asset_eligibility 硬门禁）",
  "type": "object",
  "required": [
    "coded_count",
    "empty_archetype_count",
    "archetype_signal_counts",
    "sentiment_counts",
    "signal_owner_distribution",
    "low_confidence_count",
    "coded_items"
  ],
  "properties": {
    "coded_count": {
      "type": "integer",
      "description": "编码文本总数"
    },
    "empty_archetype_count": {
      "type": "integer",
      "description": "未分配任何原型的文本数"
    },
    "archetype_signal_counts": {
      "type": "object",
      "description": "每个原型的信号频次",
      "properties": {
        "突破型": { "type": "integer" },
        "身份型": { "type": "integer" },
        "掌控型": { "type": "integer" },
        "呵护型": { "type": "integer" },
        "归属型": { "type": "integer" },
        "愉悦型": { "type": "integer" }
      }
    },
    "sentiment_counts": {
      "type": "object",
      "required": ["positive", "negative"],
      "properties": {
        "positive": { "type": "integer", "description": "positive 信号数（对象拥有该特质）" },
        "negative": { "type": "integer", "description": "negative 信号数（对象缺乏该特质）" }
      },
      "description": "正负向信号分布"
    },
    "signal_owner_distribution": {
      "type": "object",
      "description": "各 signal_owner 的频次分布",
      "properties": {
        "brand": { "type": "integer" },
        "product": { "type": "integer" },
        "product_line": { "type": "integer" },
        "founder": { "type": "integer" },
        "content": { "type": "integer" },
        "community": { "type": "integer" },
        "platform": { "type": "integer" },
        "campaign": { "type": "integer" },
        "category": { "type": "integer" },
        "competitor": { "type": "integer" }
      }
    },
    "low_confidence_count": {
      "type": "integer",
      "description": "低置信编码数"
    },
    "coded_items": {
      "type": "array",
      "description": "逐条编码结果明细。每条文本必须包含完整的字段约束（含 v3 asset_eligibility）。",
      "items": {
        "$ref": "#/$defs/coded_item"
      }
    },
    "schema_warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "编码中的异常、歧义或分布偏差记录"
    }
  },
  "$defs": {
    "coded_item": {
      "type": "object",
      "description": "单条文本的 NeedScope 编码结果。primary_eligible / secondary_only 只能用于 brand/product/product_line。",
      "required": [
        "text", "archetypes", "sentiment", "signal_owner", "signal_role",
        "evidence", "confidence", "asset_eligibility", "eligibility_reason"
      ],
      "properties": {
        "text": { "type": "string", "description": "原文" },
        "archetypes": {
          "type": "array",
          "items": { "type": "string", "enum": ["突破型", "身份型", "掌控型", "呵护型", "归属型", "愉悦型"] },
          "description": "匹配的原型列表，可以为空数组"
        },
        "sentiment": {
          "type": "string",
          "enum": ["positive", "negative"],
          "description": "positive=对象拥有该特质，negative=对象缺乏该特质"
        },
        "signal_owner": {
          "type": "string",
          "enum": ["brand", "product", "product_line", "founder", "content", "community", "platform", "campaign", "category", "competitor"],
          "description": "信号归属方"
        },
        "signal_role": {
          "type": "string",
          "enum": ["core_identity", "supporting_asset", "contextual_noise"],
          "description": "信号角色：核心身份/辅助资产/语境噪声"
        },
        "evidence": {
          "type": "string",
          "description": "文本中支持编码的关键短语"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "编码置信度"
        },
        "asset_eligibility": {
          "type": "string",
          "enum": ["primary_eligible", "secondary_only", "context_only", "exclude_from_positioning"],
          "description": "v3.2 资产资格：primary_eligible=品牌核心证据；secondary_only=品牌辅助证据；context_only=语境/旁路画像；exclude_from_positioning=排除。primary_eligible/secondary_only 只能与 brand/product/product_line 搭配。"
        },
        "eligibility_reason": {
          "type": "string",
          "description": "asset_eligibility 的判断理由。例如：'品牌直接评价，消费者明确表达品牌情感'、'社区玩梗文本，不可用于品牌定位'。"
        },
        "notes": {
          "type": "string",
          "description": "可选：编码中的歧义说明"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "asset_eligibility": { "enum": ["primary_eligible", "secondary_only"] }
            },
            "required": ["asset_eligibility"]
          },
          "then": {
            "properties": {
              "signal_owner": { "enum": ["brand", "product", "product_line"] }
            }
          }
        },
        {
          "if": {
            "properties": {
              "signal_role": { "const": "contextual_noise" }
            },
            "required": ["signal_role"]
          },
          "then": {
            "properties": {
              "asset_eligibility": { "enum": ["context_only", "exclude_from_positioning"] }
            }
          }
        }
      ]
    }
  }
}
