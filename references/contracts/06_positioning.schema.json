{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "06_positioning",
  "description": "Step 6: NeedScope 落点判定合约（v3.2 — 核心证据 + 辅助证据 + 旁路画像）",
  "type": "object",
  "required": [
    "evidence_metrics",
    "owned_signal_summary",
    "context_signal_summary",
    "primary_archetype",
    "primary_evidence_items",
    "supporting_evidence_items",
    "evidence_basis_counts",
    "excluded_high_influence_items",
    "insufficient_owned_signal_reason",
    "confidence"
  ],
  "properties": {
    "evidence_metrics": {
      "type": "object",
      "description": "信号密度、置信度分布、数据量统计等证据指标",
      "properties": {
        "total_signals": { "type": "integer" },
        "signal_density_per_prototype": { "type": "object" },
        "high_confidence_ratio": { "type": "number" },
        "platform_distribution": { "type": "object" }
      }
    },
    "owned_signal_summary": {
      "type": "object",
      "description": "Only brand/product/product_line signals that may support primary positioning.",
      "required": ["owners_included", "archetype_distribution", "evidence_count"],
      "properties": {
        "owners_included": {
          "type": "array",
          "items": { "type": "string", "enum": ["brand", "product", "product_line"] }
        },
        "archetype_distribution": { "type": "object" },
        "evidence_count": { "type": "integer" },
        "notes": { "type": "string" }
      }
    },
    "context_signal_summary": {
      "type": "object",
      "description": "Founder/content/community/platform/campaign/category/competitor signals. These must not define brand primary positioning; they may only explain context, platform split, tension, or shadow analysis.",
      "required": ["owners_included", "archetype_distribution", "evidence_count"],
      "properties": {
        "owners_included": {
          "type": "array",
          "items": { "type": "string", "enum": ["founder", "content", "community", "platform", "campaign", "category", "competitor"] }
        },
        "archetype_distribution": { "type": "object" },
        "evidence_count": { "type": "integer" },
        "context_notes": { "type": "string", "description": "Explain how context signals shape interpretation without entering brand evidence arrays." }
      }
    },
    "primary_archetype": {
      "type": "string",
      "enum": ["突破型", "身份型", "掌控型", "呵护型", "归属型", "愉悦型", "未判定"],
      "description": "主落点原型；owned signals 不足时必须为 未判定"
    },
    "primary_evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "signal_owner", "asset_eligibility", "signal_role", "archetype", "confidence"],
        "properties": {
          "text": { "type": "string", "description": "原文" },
          "signal_owner": { "type": "string", "enum": ["brand", "product", "product_line"], "description": "必须为 brand/product/product_line" },
          "asset_eligibility": { "type": "string", "enum": ["primary_eligible"], "description": "必须为 primary_eligible" },
          "signal_role": { "type": "string", "enum": ["core_identity", "supporting_asset"], "description": "v3 三重约束：必须为 core_identity 或 supporting_asset，不得为 contextual_noise" },
          "archetype": { "type": "string", "description": "指向的原型" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      },
      "description": "v3: 核心主证据条目。每条必须满足三重约束：signal_owner in brand/product/product_line AND asset_eligibility=primary_eligible AND signal_role!=contextual_noise。如果 primary_archetype=未判定，此项可为空数组。"
    },
    "supporting_evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "signal_owner", "asset_eligibility", "signal_role", "archetype", "confidence", "discount_reason"],
        "properties": {
          "text": { "type": "string", "description": "原文" },
          "signal_owner": { "type": "string", "enum": ["brand", "product", "product_line"], "description": "必须为 brand/product/product_line" },
          "asset_eligibility": { "type": "string", "enum": ["secondary_only"], "description": "必须为 secondary_only" },
          "signal_role": { "type": "string", "enum": ["core_identity", "supporting_asset"], "description": "不得为 contextual_noise" },
          "archetype": { "type": "string", "description": "指向的原型" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "discount_reason": { "type": "string", "description": "为什么只能作为辅助证据，例如轻微赛事语境/表情语气/活动语境。" }
        }
      },
      "description": "v3.2: 方向性辅助证据。只能包含 brand/product/product_line + secondary_only + 非 contextual_noise 文本，必须降权解释，不得单独决定主落点。"
    },
    "evidence_basis_counts": {
      "type": "object",
      "required": ["primary_evidence_count", "supporting_evidence_count", "positioning_evidence_count", "context_excluded_count"],
      "properties": {
        "primary_evidence_count": { "type": "integer" },
        "supporting_evidence_count": { "type": "integer" },
        "positioning_evidence_count": { "type": "integer", "description": "primary + supporting" },
        "context_excluded_count": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "description": "v3.2: 主落点证据口径说明，避免只看 primary_evidence_count 误以为数据过少。"
    },
    "excluded_high_influence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "signal_owner", "archetype", "exclusion_reason"],
        "properties": {
          "text": { "type": "string", "description": "原文" },
          "signal_owner": { "type": "string", "description": "实际 signal_owner" },
          "archetype": { "type": "string", "description": "信号指向原型" },
          "exclusion_reason": { "type": "string", "description": "排除理由（如 signal_owner=community, asset_eligibility=exclude_from_positioning）" }
        }
      },
      "description": "v3 新增：被排除的高影响信号（如高赞社区文本）。这些文本虽然有较高互动量但不满足资产资格。"
    },
    "insufficient_owned_signal_reason": {
      "type": "string",
      "description": "v3 新增：当 primary_archetype=未判定时，必须说明 owned signals 不足的具体原因（如 brand/product/product_line 信号量不足 5 条、信号分散在多个原型且无主导方向、主要证据来自社区/活动语境无法归入品牌自有信号）。如果 primary_archetype!=未判定，此项可留空。"
    },
    "secondary_archetypes": {
      "type": "array",
      "items": { "type": "string", "enum": ["突破型", "身份型", "掌控型", "呵护型", "归属型", "愉悦型"] },
      "description": "次落点原型列表（可空）"
    },
    "tension_archetypes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "archetypes": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string", "description": "张力信号描述" }
        }
      },
      "description": "张力信号列表（两个或多个原型同时出现）"
    },
    "absent_archetypes": {
      "type": "array",
      "items": { "type": "string", "enum": ["突破型", "身份型", "掌控型", "呵护型", "归属型", "愉悦型"] },
      "description": "完全无信号的缺席原型"
    },
    "noise_archetypes": {
      "type": "array",
      "items": {
        "type": "object",
          "properties": {
            "archetype": { "type": "string" },
          "signal_owner": { "type": "string" },
          "reason": { "type": "string", "description": "被判定为噪声的原因" }
        }
      },
      "description": "被判定为平台/社区噪声的原型"
    },
    "negative_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "archetype": { "type": "string" },
          "examples": { "type": "array", "items": { "type": "string" }, "description": "负向表达的文本示例" }
        }
      },
      "description": "负向缺口的原型列表"
    },
    "platform_splits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "platform": { "type": "string" },
          "primary_archetype": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "description": "不同平台/语境下的信号分布差异"
    },
    "shadow_analysis": {
      "type": "object",
      "description": "v3.2: founder/content-IP/campaign 旁路画像。仅解释人物、内容体验、活动语境或风险张力，不参与品牌主证据。",
      "properties": {
        "founder": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "archetype_summary": { "type": "object" },
            "evidence_count": { "type": "integer" },
            "notes": { "type": "string" }
          }
        },
        "content_ip": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "archetype_summary": { "type": "object" },
            "evidence_count": { "type": "integer" },
            "notes": { "type": "string" }
          }
        },
        "campaign_context": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "archetype_summary": { "type": "object" },
            "evidence_count": { "type": "integer" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "此落点判定的整体置信度"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "primary_archetype": {
            "enum": ["突破型", "身份型", "掌控型", "呵护型", "归属型", "愉悦型"]
          }
        },
        "required": ["primary_archetype"]
      },
      "then": {
        "properties": {
          "primary_evidence_items": { "minItems": 1 }
        }
      }
    }
  ]
}
