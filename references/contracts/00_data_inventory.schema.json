{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "00_data_inventory",
  "description": "Step 0: 数据盘点与对象类型判定合约（v3）",
  "type": "object",
  "required": [
    "analysis_object_type",
    "data_sources",
    "platform_contexts",
    "supported_layers",
    "max_confidence_level",
    "context_risk_flags",
    "context_risk_level",
    "max_confidence_ceiling",
    "analysis_object_boundary",
    "human_decision_required"
  ],
  "properties": {
    "analysis_object_type": {
      "type": "string",
      "enum": ["brand", "product", "product_line", "founder", "public_person", "content_ip", "campaign", "platform_community", "mixed"],
      "description": "分析对象类型。mixed 表示混合型，需在说明中标明具体组合"
    },
    "analysis_object_boundary": {
      "type": "string",
      "description": "分析对象边界说明：明确本次分析的品牌/产品/人物的范围，包括对象名称、品类归属、数据覆盖的时间范围和市场范围。用于防止对象飘移和误解。"
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type", "record_count"],
        "properties": {
          "path": { "type": "string", "description": "数据文件路径" },
          "type": {
            "type": "string",
            "enum": ["consumer_review", "official_content", "influencer_content", "search_behavior", "competitor_data", "product_listing", "social_discussion"],
            "description": "数据类型"
          },
          "record_count": { "type": "integer", "description": "记录数" },
          "fields": { "type": "array", "items": { "type": "string" }, "description": "字段名列表" },
          "sample": { "type": "array", "description": "前 3 条样本" }
        }
      },
      "minItems": 1
    },
    "platform_contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["data_source_index", "context"],
        "properties": {
          "data_source_index": { "type": "integer", "description": "对应 data_sources 中的索引" },
          "context": {
            "type": "string",
            "enum": ["fan_field", "public_discussion", "official_expression", "influencer_planting", "search_behavior", "authentic_review"]
          }
        }
      },
      "minItems": 1
    },
    "supported_layers": {
      "type": "array",
      "items": { "type": "string", "enum": ["A", "B", "C"] },
      "description": "可支持的 NeedScope 分析层级。A=竞品地图，B=品牌诊断，C=产品线分级"
    },
    "max_confidence_level": {
      "type": "string",
      "enum": ["decision", "directional", "exploratory_usable", "exploratory_thin"],
      "description": "基于当前数据源组合的最高置信度等级（v2 兼容字段）"
    },
    "context_risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "celebrity_or_ambassador",
          "fan_community",
          "platform_activity",
          "event_or_tournament",
          "campaign_mechanic",
          "meme_or_comment_culture",
          "category_discussion_dominant",
          "competitor_hijack"
        ]
      },
      "minItems": 1,
      "description": "数据中存在的上下文风险标记。每个风险标记表明数据可能被非品牌信号污染，需在后续步骤中做针对性处理。"
    },
    "context_risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "综合上下文风险等级。high = 存在多个强风险标记且可能显著影响品牌信号纯度；medium = 存在风险标记但可控；low = 无明显上下文风险。"
    },
    "max_confidence_ceiling": {
      "type": "string",
      "enum": ["decision", "directional", "exploratory_usable", "exploratory_thin", "not_assessable"],
      "description": "基于 context_risk 调整后的最高置信度上限。高风险上下文即使数据量大，也必须将上限下调。例如：高赞粉丝场景数据即使记录数>100条，上限也只能到 directional。"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "数据质量警告列表"
    },
    "human_decision_required": {
      "type": "boolean",
      "description": "是否存在需要用户确认的边界争议（如对象类型不明确、品类边界不清）"
    }
  }
}
